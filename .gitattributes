# Auto-detect text files and normalise line endings to LF
* text=auto eol=lf

# Explicitly declare binary file types (no line-ending conversion)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.svg  binary
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary

# APK / build artefacts
*.apk  binary
*.aab  binary
*.ipa  binary
*.jks  binary
*.p12  binary
*.keystore binary

# Force LF for source files
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
